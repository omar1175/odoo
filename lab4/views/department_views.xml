<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List View -->
    <record id="view_hms_department_list" model="ir.ui.view">
        <field name="name">hms.department.list</field>
        <field name="model">hms.department</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="capacity"/>
                <field name="is_opened"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_hms_department_form" model="ir.ui.view">
        <field name="name">hms.department.form</field>
        <field name="model">hms.department</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="capacity"/>
                        <field name="is_opened"/>
                    </group>
                    <notebook>
                        <page string="Doctors">
                            <field name="doctor_ids">
                                <list>
                                    <field name="first_name"/>
                                    <field name="last_name"/>
                                </list>
                            </field>
                        </page>
                        <page string="Patients">
                            <field name="patient_ids">
                                <list>
                                    <field name="first_name"/>
                                    <field name="last_name"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="hms_department_action" model="ir.actions.act_window">
        <field name="name">Departments</field>
        <field name="res_model">hms.department</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Departments Menu: visible to both groups -->
    <menuitem id="hms_department_menu"
              name="Departments"
              parent="hms_root_menu"
              action="hms_department_action"
              groups="hms.group_hms_user,hms.group_hms_manager"/>

</odoo>
