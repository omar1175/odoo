<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List View -->
    <record id="view_hms_doctor_list" model="ir.ui.view">
        <field name="name">hms.doctor.list</field>
        <field name="model">hms.doctor</field>
        <field name="arch" type="xml">
            <list>
                <field name="first_name"/>
                <field name="last_name"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_hms_doctor_form" model="ir.ui.view">
        <field name="name">hms.doctor.form</field>
        <field name="model">hms.doctor</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="image" widget="image"/>
                    </group>
                    <group>
                        <field name="first_name"/>
                        <field name="last_name"/>
                        <field name="department_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="hms_doctor_action" model="ir.actions.act_window">
        <field name="name">Doctors</field>
        <field name="res_model">hms.doctor</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Doctors Menu: visible to Manager only -->
    <menuitem id="hms_doctor_menu"
              name="Doctors"
              parent="hms_root_menu"
              action="hms_doctor_action"
              groups="hms.group_hms_manager"/>

</odoo>
