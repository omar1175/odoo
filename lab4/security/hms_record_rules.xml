<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!--
            HMS User: can only read/write/create patients they created.
            Manager group bypasses this rule (no rule = see all).
        -->
        <record id="rule_hms_patient_user_own" model="ir.rule">
            <field name="name">HMS Patient: User sees own records only</field>
            <field name="model_id" ref="model_hms_patient"/>
            <field name="domain_force">[('create_uid', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_hms_user'))]"/>
            <field name="perm_read"  eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!--
            HMS Manager: can access ALL patient records (no domain restriction).
        -->
        <record id="rule_hms_patient_manager_all" model="ir.rule">
            <field name="name">HMS Patient: Manager sees all records</field>
            <field name="model_id" ref="model_hms_patient"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_hms_manager'))]"/>
            <field name="perm_read"  eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>
